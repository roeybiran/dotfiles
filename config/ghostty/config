theme = dark:"Builtin Solarized Dark",light:"Builtin Solarized Light"

unfocused-split-fill = black
bell-features = system, no-title, attention, no-border
shell-integration-features = ssh-terminfo, ssh-env, no-title
quick-terminal-size = 50%

# key bindings

keybind = global:ctrl+super+alt+shift+t=toggle_quick_terminal
keybind = ctrl+b>shift+\=new_split:right
keybind = ctrl+b>-=new_split:down
keybind = ctrl+b>x=close_surface
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>k=clear_screen
keybind = super+r=reload_config

keybind = alt+f=write_scrollback_file:open
